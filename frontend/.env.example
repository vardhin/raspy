# Base URL of the Raspy spine backend.
#
# Leave EMPTY in production: the spine serves this bundle, so the frontend talks
# to its own origin (/api/...). Set it only when the frontend runs on a different
# origin than the backend — e.g. `vite dev` on :5173, or a Capacitor APK.
#
# Example (dev pointing at the deployed spine):
# PUBLIC_API_BASE=https://app.vardhin.com
PUBLIC_API_BASE=
